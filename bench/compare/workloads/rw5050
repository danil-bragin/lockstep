# YCSB workload: RW5050  (50% read / 50% update — YCSB workload A shape).
#
# SCHEMA workload "rw5050" = 50/50 read/update. Throughput counts every committed op
# (reads + writes); the reads are point gets, the writes are committed updates.
#
# Adapter overrides per cell: recordcount, operationcount, fieldlength(==value_bytes),
# threadcount(==concurrency).

recordcount=10000
operationcount=20000

fieldcount=1
fieldlength=16
fieldlengthdistribution=constant

readproportion=0.5
updateproportion=0.5
insertproportion=0.0
scanproportion=0.0
readmodifywriteproportion=0.0

requestdistribution=uniform
measurementtype=histogram
