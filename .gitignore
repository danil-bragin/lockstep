# Build directories (CMakePresets binaryDir is build/<preset>)
/build/
build/
cmake-build-*/
out/

# CMake artifacts that can leak outside binaryDir
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
Testing/

# Compiled objects / libs / binaries
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe

# Coverage / sanitizer / profiling output
*.gcda
*.gcno
*.gcov
*.profraw
*.profdata
coverage/

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Python (lint + mutation tooling live under tools/)
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# macOS
.DS_Store
tools/tla/tla2tools.jar

# TLC model-checker scratch (state queue / checkpoints) — never commit, can be GBs
states/
*.st
states_*/
